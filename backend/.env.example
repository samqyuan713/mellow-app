# ══════════════════════════════════════════
# Kindred — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ══════════════════════════════════════════

# ── App ──────────────────────────────────
APP_NAME=Kindred
APP_ENV=development
DEBUG=True
SECRET_KEY=replace_with_64_char_random_string

# ── Database ─────────────────────────────
# Local development:
DATABASE_URL=postgresql+asyncpg://mellow:mellow@localhost:5432/mellow
# Railway (auto-provided):
# DATABASE_URL=postgresql+asyncpg://postgres:xxxx@containers-us-west-xxx.railway.app:5432/railway

REDIS_URL=redis://localhost:6379/0

# ── JWT ──────────────────────────────────
JWT_SECRET=replace_with_another_64_char_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google OAuth ─────────────────────────
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── Cloudinary ───────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stripe ───────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
# Create prices in Stripe Dashboard then paste IDs here:
STRIPE_KINDRED_PRICE_ID=price_
STRIPE_KINDRED_PLUS_PRICE_ID=price_

# ── SendGrid ─────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.
FROM_EMAIL=hello@mellow.app
FROM_NAME=Kindred

# ── Twilio (optional SMS verification) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Frontend / CORS ──────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Subscription Limits ──────────────────
FREE_DAILY_SWIPES=10
FREE_MESSAGES_PER_MATCH=3
FREE_MAX_PHOTOS=2
KINDRED_MAX_PHOTOS=6
KINDRED_PLUS_MAX_PHOTOS=6
